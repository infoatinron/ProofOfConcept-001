<usecaseModel>
    <usecase id="UCX" name="UseCaseName">
        <primaryActor>ActorName</primaryActor>
        <goal>Short description of the goal</goal>

        <parameters>
            <input>
            <!-- name = parameter name -->
            <!-- type = datatype -->
            <!-- required = true/false -->            
                <param name="Email" type="string" required="true"/>
            </input>
            <output>
                <param name="Success" type="bool"/>
            </output>
        </parameters>

        <extends>
            <extend ref="UC3" condition="IsFirstTimeCustomer" description="ApplyWelcomeDiscount" />
        </extends> 

        <includes>
            <include ref="UC2" description="Check if email exists" />
        </includes>

        <preconditions>
            <condition>User is not logged in</condition>
        </preconditions>

        <postconditions>
            <condition>Account is created</condition>
        </postconditions>

        <faults>
        <fault id="F1">
            <condition>Borrower has reached the maximum number of active loans</condition>
            <systemResponse>Loan request is rejected</systemResponse>
        </fault>
        <fault id="F2">
            <condition>Book is already loaned out</condition>
            <systemResponse>Loan request is rejected</systemResponse>
        </fault>
        <fault id="F3">
            <condition>Borrower has outstanding fines exceeding allowed limit</condition>
            <systemResponse>Loan request is rejected</systemResponse>
        </fault>
        </faults>

    </usecase>

    <usecase id="UC2" name="ValidateEmail"></usecase>
    <usecase id="UC3" name="ApplyDiscount"></usecase>
</usecaseModel>


